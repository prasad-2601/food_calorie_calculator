{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "python",
  "buildCommand": null,
  "installCommand": "",
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/styles.css",
      "destination": "/frontend/styles.css"
    },
    {
      "source": "/app.js",
      "destination": "/frontend/app.js"
    }
  ],
  "functions": {
    "api/*.py": {
      "maxDuration": 10
    }
  }
}
